import "sys" as _sys;

var _tests = [];

function test(name, fn) {
    _tests.push({ name: name, fn: fn });
}

function equal(actual, expected) {
    if (actual != expected) {
        throw "expected " + _show(expected) + ", got " + _show(actual);
    }
}

function not_equal(actual, expected) {
    if (actual == expected) {
        throw "expected NOT " + _show(expected) + ", but got it";
    }
}

function is_true(v)  { if (v != true)  { throw "expected true, got "  + _show(v); } }
function is_false(v) { if (v != false) { throw "expected false, got " + _show(v); } }
function is_null(v)  { if (v != null)  { throw "expected null, got "  + _show(v); } }
function not_null(v) { if (v == null)  { throw "expected not-null, got null"; } }

function contains(haystack, needle) {
    if (type(haystack) == "string") {
        if (haystack.index_of(needle) < 0) {
            throw "expected " + _show(haystack) + " to contain " + _show(needle);
        }
        return;
    }
    if (type(haystack) == "list") {
        var i = 0;
        while (i < haystack.length) {
            if (haystack[i] == needle) { return; }
            i = i + 1;
        }
        throw "expected list to contain " + _show(needle);
    }
    throw "contains: expected string or list, got " + type(haystack);
}

function throws(fn) {
    var threw = false;
    try { fn(); } catch (e) { threw = true; }
    if (not threw) { throw "expected fn to throw, but it returned normally"; }
}

function throws_with(fn, message_substring) {
    var threw = false;
    var msg = "";
    try { fn(); } catch (e) { threw = true; msg = str(e); }
    if (not threw) {
        throw "expected fn to throw, but it returned normally";
    }
    if (msg.index_of(message_substring) < 0) {
        throw "expected thrown message to contain " + _show(message_substring)
            + ", got " + _show(msg);
    }
}

function run() {
    var passed = 0;
    var failed = 0;
    var i = 0;
    while (i < _tests.length) {
        var t = _tests[i];
        var err = null;
        try { t.fn(); } catch (e) { err = e; }
        if (err == null) {
            print("ok  " + t.name);
            passed = passed + 1;
        } else {
            print("FAIL " + t.name + " — " + str(err));
            failed = failed + 1;
        }
        i = i + 1;
    }
    print("");
    print(str(passed) + " passed, " + str(failed) + " failed");
    if (failed > 0) { _sys.exit(1); }
}

function _show(v) {
    if (v == null)              { return "null"; }
    if (type(v) == "string")    { return "\"" + v + "\""; }
    return str(v);
}
