import "net"       as _net;
import "tls"       as _tls;
import "http"      as _http;
import "url"       as _url;
import "json"      as _json;
import "io"        as _io;
import "timers"    as _timers;
import "multipart" as _mp;
import "template"  as _tpl;
import "ws"        as _ws;
import "cookie"   as _cookie;

var DEFAULT_IDLE_TIMEOUT_MS = 30000;
var DEFAULT_MAX_BODY_SIZE   = 10485760;

function text(s)     {
    return { status: 200, headers: { "Content-Type": "text/plain; charset=utf-8" }, body: s };
}

function html(s)     {
    return { status: 200, headers: { "Content-Type": "text/html; charset=utf-8" }, body: s };
}

function json(value) {
    return { status: 200, headers: { "Content-Type": "application/json; charset=utf-8" },
             body: _json.stringify(value) };
}

function redirect(url) {
    return { status: 302, headers: { "Location": url }, body: "" };
}

function error(status, msg) {
    if (msg == null) { msg = _status_text(status); }
    return { status: status,
             headers: { "Content-Type": "text/plain; charset=utf-8" },
             body: msg };
}

function file(path) {
    return { _kind: "file", path: path };
}

function view(path, ctx) {
    return { status:  200,
             headers: { "Content-Type": "text/html; charset=utf-8" },
             body:    _tpl.render(path, ctx) };
}

function set_views(dir)       { _tpl.set_views(dir); }
function clear_views_cache()  { _tpl.clear_cache(); }

function upgrade(req) {
    if (req._conn == null) {
        throw "web.upgrade: req has no underlying conn";
    }
    var ws_conn = _ws.accept(req._conn, req);
    req._upgraded = true;
    return ws_conn;
}

function parse_form(req) { return _url.parse_query(req.body); }
function parse_json(req) { return _json.parse(req.body); }

function _status_text(s) {
    if (s == 200) { return "OK"; }
    if (s == 201) { return "Created"; }
    if (s == 204) { return "No Content"; }
    if (s == 301) { return "Moved Permanently"; }
    if (s == 302) { return "Found"; }
    if (s == 304) { return "Not Modified"; }
    if (s == 400) { return "Bad Request"; }
    if (s == 401) { return "Unauthorized"; }
    if (s == 403) { return "Forbidden"; }
    if (s == 404) { return "Not Found"; }
    if (s == 405) { return "Method Not Allowed"; }
    if (s == 500) { return "Internal Server Error"; }
    if (s == 501) { return "Not Implemented"; }
    if (s == 503) { return "Service Unavailable"; }
    return "OK";
}

function _has_header(h, name_lower) {
    for (var k of h.keys()) {
        if (k.to_lower() == name_lower) { return true; }
    }
    return false;
}

function _content_type_for(path) {
    var ext = "";
    var i = path.byte_length - 1;
    while (i >= 0) {
        var b = path.byte_at(i);
        if (b == 46) { ext = path.byte_slice(i).to_lower(); }
        if (b == 46 or b == 47 or b == 92) { i = -1; }
        i = i - 1;
    }
    if (ext == ".html" or ext == ".htm") { return "text/html; charset=utf-8"; }
    if (ext == ".css")                    { return "text/css; charset=utf-8"; }
    if (ext == ".js")                     { return "application/javascript"; }
    if (ext == ".json")                   { return "application/json"; }
    if (ext == ".txt" or ext == ".md")    { return "text/plain; charset=utf-8"; }
    if (ext == ".png")                    { return "image/png"; }
    if (ext == ".jpg" or ext == ".jpeg")  { return "image/jpeg"; }
    if (ext == ".gif")                    { return "image/gif"; }
    if (ext == ".svg")                    { return "image/svg+xml"; }
    if (ext == ".ico")                    { return "image/x-icon"; }
    if (ext == ".pdf")                    { return "application/pdf"; }
    if (ext == ".zip")                    { return "application/zip"; }
    if (ext == ".wasm")                   { return "application/wasm"; }
    return "application/octet-stream";
}

function _coerce(value) {
    if (value == null) {
        return { status: 204, headers: {}, body: "" };
    }
    var t = type(value);
    if (t == "string") {
        return { status: 200,
                 headers: { "Content-Type": "text/plain; charset=utf-8" },
                 body: value };
    }
    if (t == "number" or t == "bool") {
        return { status: 200,
                 headers: { "Content-Type": "text/plain; charset=utf-8" },
                 body: str(value) };
    }
    if (t == "list") {
        if (value.length >= 1 and value.length <= 3
            and type(value[0]) == "number"
            and value[0] >= 100 and value[0] <= 599) {
            var r = { status: value[0], headers: {}, body: "" };
            if (value.length >= 2) {
                var inner = _coerce(value[1]);
                r.body = inner.body;
                for (var k of inner.headers.keys()) { r.headers[k] = inner.headers[k]; }
                if (inner._kind != null) { r._kind = inner._kind; r.path = inner.path; }
            }
            if (value.length >= 3) {
                for (var hk of value[2].keys()) { r.headers[hk] = value[2][hk]; }
            }
            return r;
        }
        return { status: 200,
                 headers: { "Content-Type": "application/json; charset=utf-8" },
                 body: _json.stringify(value) };
    }
    if (t == "map") {
        if (value._kind == "file") {
            if (value.headers == null) { value.headers = {}; }
            return value;
        }
        if (value.status != null and (value.body != null or value.headers != null
                                       or value.cookies != null)) {
            var raw = {
                status:  value.status,
                body:    value.body,
                headers: value.headers,
                cookies: value.cookies
            };
            if (raw.body == null)    { raw.body = ""; }
            if (raw.headers == null) { raw.headers = {}; }
            return raw;
        }
        return { status: 200,
                 headers: { "Content-Type": "application/json; charset=utf-8" },
                 body: _json.stringify(value) };
    }
    return { status: 200,
             headers: { "Content-Type": "text/plain; charset=utf-8" },
             body: str(value) };
}

function _set_header(headers, name, value) {
    var lower = name.to_lower();
    for (var k of headers.keys()) {
        if (k.to_lower() == lower) { headers[k] = value; return; }
    }
    headers[name] = value;
}

function _write_response(conn, resp, on_done) {
    if (resp._kind == "file") {
        _write_file(conn, resp, on_done);
        return;
    }
    var status = resp.status;
    if (status == null) { status = 200; }
    var headers = resp.headers;
    if (headers == null) { headers = {}; }
    var body = resp.body;
    if (body == null) { body = ""; }

    if (status != 204 and not _has_header(headers, "content-type")) {
        headers["Content-Type"] = "text/plain; charset=utf-8";
    }
    if (not _has_header(headers, "content-length")) {
        headers["Content-Length"] = str(body.byte_length);
    }

    var out = "HTTP/1.1 " + str(status) + " " + _status_text(status) + "\r\n";
    for (var k of headers.keys()) {
        out = out + k + ": " + str(headers[k]) + "\r\n";
    }
    if (resp.cookies != null and type(resp.cookies) == "list") {
        var ci = 0;
        while (ci < resp.cookies.length) {
            out = out + "Set-Cookie: " + str(resp.cookies[ci]) + "\r\n";
            ci = ci + 1;
        }
    }
    out = out + "\r\n" + body;

    conn.write(out, function (err) { on_done(); });
}

function _write_file(conn, resp, on_done) {
    var path = resp.path;
    if (not _io.exists(path)) {
        _write_response(conn, error(404), on_done);
        return;
    }
    var st = _io.stat(path);
    if (st.is_dir) {
        _write_response(conn, error(403, "Forbidden"), on_done);
        return;
    }

    var headers = resp.headers;
    if (headers == null) { headers = {}; }
    if (not _has_header(headers, "content-type")) {
        headers["Content-Type"] = _content_type_for(path);
    }
    _set_header(headers, "Content-Length", str(st.bytes));

    var status = resp.status;
    if (status == null) { status = 200; }

    var head = "HTTP/1.1 " + str(status) + " " + _status_text(status) + "\r\n";
    for (var k of headers.keys()) {
        head = head + k + ": " + str(headers[k]) + "\r\n";
    }
    head = head + "\r\n";

    conn.write(head, function (err) {
        if (err != null) { on_done(); return; }
        if (st.bytes == 0) { on_done(); return; }
        var src = _io.open_read(path);
        var pump = function () {};
        pump = function () {
            src.read(65536, function (rerr, chunk) {
                if (rerr != null or chunk == null) {
                    src.close();
                    on_done();
                    return;
                }
                conn.write(chunk, function (werr) {
                    if (werr != null) { src.close(); on_done(); return; }
                    pump();
                });
            });
        };
        pump();
    });
}

function _enrich(parsed) {
    var qmark = parsed.url.index_of("?");
    if (qmark >= 0) {
        parsed.path  = parsed.url.byte_slice(0, qmark);
        parsed.query = _url.parse_query(parsed.url.byte_slice(qmark + 1));
    } else {
        parsed.path  = parsed.url;
        parsed.query = {};
    }
    return parsed;
}

function _enrich_for_app(req, params) {
    req.params = params;
    req.json   = function () { return _json.parse(req.body); };
    req.form   = function () { return _url.parse_query(req.body); };
    req.cookies = function () { return _cookie.parse(req.headers["cookie"]); };
    req.file   = function (name) {
        var parts = _parse_multipart_cached(req);
        var i = 0;
        while (i < parts.length) {
            if (parts[i].name == name and parts[i].filename != null) { return parts[i]; }
            i = i + 1;
        }
        return null;
    };
    req.files = function () {
        var parts = _parse_multipart_cached(req);
        var out = [];
        var i = 0;
        while (i < parts.length) {
            if (parts[i].filename != null) { out.push(parts[i]); }
            i = i + 1;
        }
        return out;
    };
    req.fields = function () {
        var parts = _parse_multipart_cached(req);
        var out = {};
        var i = 0;
        while (i < parts.length) {
            if (parts[i].filename == null) { out[parts[i].name] = parts[i].body; }
            i = i + 1;
        }
        return out;
    };
    return req;
}

function _parse_multipart_cached(req) {
    if (req._mp_cache != null) { return req._mp_cache; }
    var ct = req.headers["content-type"];
    if (ct == null) { req._mp_cache = []; return req._mp_cache; }
    var bidx = ct.index_of("boundary=");
    if (bidx < 0)  { req._mp_cache = []; return req._mp_cache; }
    var boundary = ct.byte_slice(bidx + 9).trim();
    var semi = boundary.index_of(";");
    if (semi >= 0) { boundary = boundary.byte_slice(0, semi).trim(); }
    if (boundary.byte_length >= 2
        and boundary.byte_at(0) == 34
        and boundary.byte_at(boundary.byte_length - 1) == 34) {
        boundary = boundary.byte_slice(1, boundary.byte_length - 1);
    }
    req._mp_cache = _mp.decode(req.body, boundary);
    return req._mp_cache;
}

function _handle_connection(conn, handler, server_opts) {
    var max_body  = DEFAULT_MAX_BODY_SIZE;
    var idle_ms   = DEFAULT_IDLE_TIMEOUT_MS;
    if (server_opts != null) {
        if (server_opts.max_body_size != null) { max_body = server_opts.max_body_size; }
        if (server_opts.idle_timeout  != null) { idle_ms  = server_opts.idle_timeout; }
    }

    var buf         = "";
    var busy        = false;
    var conn_closed = false;
    var idle_cancel = null;

    function close_now() {
        if (conn_closed) { return; }
        conn_closed = true;
        if (idle_cancel != null) { idle_cancel(); idle_cancel = null; }
        conn.close();
    }

    function reset_idle() {
        if (conn_closed)        { return; }
        if (idle_cancel != null) { idle_cancel(); }
        if (idle_ms > 0) {
            idle_cancel = _timers.set(idle_ms, function () {
                close_now();
            });
        }
    }

    function dispatch_one() {}
    dispatch_one = function () {
        if (busy or conn_closed)  { return; }
        if (buf.byte_length == 0) { return; }
        var parsed = _http.parse_request(buf);
        if (not parsed.complete)  { return; }

        busy = true;
        buf  = buf.byte_slice(parsed.consumed);

        var keep_alive = (parsed.version == "1.1");
        var ch = parsed.headers["connection"];
        if (ch != null) {
            var chl = ch.to_lower();
            if (chl.index_of("close") >= 0)           { keep_alive = false; }
            else if (chl.index_of("keep-alive") >= 0) { keep_alive = true; }
        }

        var req = _enrich(parsed);
        req._conn     = conn;
        req._upgraded = false;
        var responded = false;

        var send_canonical = function (resp) {
            if (responded or conn_closed) { return; }
            responded = true;
            if (resp.headers == null) { resp.headers = {}; }
            var conn_value = "close";
            if (keep_alive) { conn_value = "keep-alive"; }
            _set_header(resp.headers, "Connection", conn_value);
            _write_response(conn, resp, function () {
                busy = false;
                if (not keep_alive) {
                    close_now();
                } else {
                    reset_idle();
                    dispatch_one();
                }
            });
        };

        req.respond = function (r) {
            if (req._upgraded) { return; }
            send_canonical(_coerce(r));
        };

        var resp_value = null;
        try {
            resp_value = handler(req);
        } catch (e) {
            resp_value = { status: 500, body: "Internal Server Error" };
        }
        if (req._upgraded) {
            if (idle_cancel != null) { idle_cancel(); idle_cancel = null; }
            return;
        }
        if (resp_value != null) {
            send_canonical(_coerce(resp_value));
        }
    };

    function reject_too_large() {
        if (conn_closed) { return; }
        var body = "request payload too large";
        var resp = "HTTP/1.1 413 Payload Too Large\r\n"
                 + "Content-Type: text/plain; charset=utf-8\r\n"
                 + "Content-Length: " + str(body.byte_length) + "\r\n"
                 + "Connection: close\r\n\r\n"
                 + body;
        conn.write(resp, function (err) { close_now(); });
    }

    conn.on_data(function (chunk) {
        if (conn_closed) { return; }
        if (max_body > 0 and buf.byte_length + chunk.byte_length > max_body) {
            if (busy) { close_now(); }
            else      { reject_too_large(); }
            return;
        }
        buf = buf + chunk;
        reset_idle();
        dispatch_one();
    });

    conn.on_end(function () { close_now(); });

    reset_idle();
}

function serve(opts, handler) {
    var port = opts.port;
    if (port == null) { port = 0; }
    if (opts.tls != null) {
        return _tls.listen(port, opts.tls, function (conn) {
            _handle_connection(conn, handler, opts);
        });
    }
    return _net.tcp_listen(port, function (conn) {
        _handle_connection(conn, handler, opts);
    });
}

function serve_stream(opts, handler) {
    var port = opts.port;
    if (port == null) { port = 0; }
    if (opts.tls != null) {
        return _tls.listen(port, opts.tls, function (conn) {
            _handle_streaming_connection(conn, handler, opts);
        });
    }
    return _net.tcp_listen(port, function (conn) {
        _handle_streaming_connection(conn, handler, opts);
    });
}

function _parse_request_head(buf) {
    var sep = buf.index_of("\r\n\r\n");
    if (sep < 0) { return null; }
    var head_text = buf.byte_slice(0, sep);
    var lines = head_text.split("\r\n");
    if (lines.length < 1) { return null; }

    var first = lines[0];
    var sp1 = first.index_of(" ");
    if (sp1 < 0) { return null; }
    var method = first.byte_slice(0, sp1);
    var rest1  = first.byte_slice(sp1 + 1);
    var sp2 = rest1.index_of(" ");
    if (sp2 < 0) { return null; }
    var url = rest1.byte_slice(0, sp2);
    var vfull = rest1.byte_slice(sp2 + 1);
    var version = "1.1";
    var slash = vfull.index_of("/");
    if (slash >= 0) { version = vfull.byte_slice(slash + 1); }

    var headers = {};
    var i = 1;
    while (i < lines.length) {
        var ln = lines[i];
        var colon = ln.index_of(":");
        if (colon > 0) {
            var k = ln.byte_slice(0, colon).trim().to_lower();
            var v = ln.byte_slice(colon + 1).trim();
            headers[k] = v;
        }
        i = i + 1;
    }

    return {
        method:   method,
        url:      url,
        version:  version,
        headers:  headers,
        head_end: sep + 4
    };
}

function _handle_streaming_connection(conn, handler, server_opts) {
    var max_body  = DEFAULT_MAX_BODY_SIZE;
    var idle_ms   = DEFAULT_IDLE_TIMEOUT_MS;
    if (server_opts != null) {
        if (server_opts.max_body_size != null) { max_body = server_opts.max_body_size; }
        if (server_opts.idle_timeout  != null) { idle_ms  = server_opts.idle_timeout; }
    }

    var buf            = "";
    var phase          = "headers";
    var conn_closed    = false;
    var idle_cancel    = null;
    var keep_alive     = true;
    var responded      = false;
    var body_remaining = 0;
    var on_body_chunk  = null;
    var on_body_end    = null;
    var current_req    = null;

    var chunked        = false;
    var ch_state       = "size";
    var ch_remaining   = 0;

    function close_now() {
        if (conn_closed) { return; }
        conn_closed = true;
        if (idle_cancel != null) { idle_cancel(); idle_cancel = null; }
        conn.close();
    }
    function reset_idle() {
        if (conn_closed) { return; }
        if (idle_cancel != null) { idle_cancel(); }
        if (idle_ms > 0) {
            idle_cancel = _timers.set(idle_ms, function () { close_now(); });
        }
    }
    function reject_too_large() {
        if (conn_closed) { return; }
        var body = "request payload too large";
        var resp = "HTTP/1.1 413 Payload Too Large\r\n"
                 + "Content-Type: text/plain; charset=utf-8\r\n"
                 + "Content-Length: " + str(body.byte_length) + "\r\n"
                 + "Connection: close\r\n\r\n" + body;
        conn.write(resp, function (err) { close_now(); });
    }

    function reset_for_next_request() {
        phase          = "headers";
        responded      = false;
        body_remaining = 0;
        on_body_chunk  = null;
        on_body_end    = null;
        current_req    = null;
        chunked        = false;
        ch_state       = "size";
        ch_remaining   = 0;
    }

    function send_canonical(resp) {
        if (responded or conn_closed) { return; }
        responded = true;
        if (resp.headers == null) { resp.headers = {}; }
        var conn_value = "close";
        if (keep_alive) { conn_value = "keep-alive"; }
        _set_header(resp.headers, "Connection", conn_value);
        _write_response(conn, resp, function () {
            if (not keep_alive) {
                close_now();
            } else {
                reset_idle();
                reset_for_next_request();
                dispatch();
            }
        });
    }

    function dispatch() {}
    dispatch = function () {
        if (conn_closed) { return; }

        if (phase == "headers") {
            var head = _parse_request_head(buf);
            if (head == null) { return; }
            buf = buf.byte_slice(head.head_end);

            var qmark = head.url.index_of("?");
            if (qmark >= 0) {
                head.path  = head.url.byte_slice(0, qmark);
                head.query = _url.parse_query(head.url.byte_slice(qmark + 1));
            } else {
                head.path  = head.url;
                head.query = {};
            }
            keep_alive = (head.version == "1.1");
            var ch = head.headers["connection"];
            if (ch != null) {
                var chl = ch.to_lower();
                if (chl.index_of("close") >= 0)           { keep_alive = false; }
                else if (chl.index_of("keep-alive") >= 0) { keep_alive = true; }
            }
            var te = head.headers["transfer-encoding"];
            if (te != null and te.to_lower().index_of("chunked") >= 0) {
                chunked  = true;
                ch_state = "size";
            } else {
                var cl = head.headers["content-length"];
                if (cl != null) {
                    var n = to_number(cl);
                    if (n != null and n > 0) { body_remaining = n; }
                }
            }

            head.body        = null;
            head.body_stream = {
                on_chunk: function (fn) { on_body_chunk = fn; },
                on_end:   function (fn) { on_body_end   = fn; }
            };
            head.respond = function (r) { send_canonical(_coerce(r)); };
            current_req  = head;

            phase = "body";

            var resp_value = null;
            try {
                resp_value = handler(head);
            } catch (e) {
                resp_value = { status: 500, body: "Internal Server Error" };
            }
            if (resp_value != null) {
                if (on_body_chunk == null) { on_body_chunk = function (c) {}; }
                var saved = resp_value;
                if (on_body_end == null) {
                    on_body_end = function () { send_canonical(_coerce(saved)); };
                }
            }
        }

        if (phase == "body") {
            if (chunked) {
                drain_chunked();
            } else {
                if (body_remaining > 0 and buf.byte_length > 0) {
                    var take = buf.byte_length;
                    if (take > body_remaining) { take = body_remaining; }
                    var chunk = buf.byte_slice(0, take);
                    buf = buf.byte_slice(take);
                    body_remaining = body_remaining - take;
                    if (on_body_chunk != null) { on_body_chunk(chunk); }
                }
                if (body_remaining == 0) {
                    phase = "awaiting_respond";
                    if (on_body_end != null) { on_body_end(); }
                }
            }
        }
    };

    function drain_chunked() {
        var progressed = true;
        while (progressed and not conn_closed) {
            progressed = false;
            if (ch_state == "size") {
                var nl = buf.index_of("\r\n");
                if (nl < 0) { return; }
                var size_line = buf.byte_slice(0, nl);
                var semi = size_line.index_of(";");
                if (semi >= 0) { size_line = size_line.byte_slice(0, semi); }
                var n = _parse_hex(size_line.trim());
                if (n == null) {
                    if (phase != "awaiting_respond") { phase = "awaiting_respond"; }
                    if (on_body_end != null) { on_body_end(); }
                    return;
                }
                ch_remaining = n;
                buf = buf.byte_slice(nl + 2);
                if (n == 0) { ch_state = "trailer"; }
                else        { ch_state = "data"; }
                progressed = true;
            } else if (ch_state == "data") {
                if (buf.byte_length == 0) { return; }
                var take = buf.byte_length;
                if (take > ch_remaining) { take = ch_remaining; }
                var chunk = buf.byte_slice(0, take);
                buf = buf.byte_slice(take);
                ch_remaining = ch_remaining - take;
                if (on_body_chunk != null) { on_body_chunk(chunk); }
                if (ch_remaining == 0) { ch_state = "after_data"; }
                progressed = true;
            } else if (ch_state == "after_data") {
                if (buf.byte_length < 2) { return; }
                buf = buf.byte_slice(2);
                ch_state = "size";
                progressed = true;
            } else if (ch_state == "trailer") {
                if (buf.byte_length < 2) { return; }
                if (buf.byte_at(0) == 13 and buf.byte_at(1) == 10) {
                    buf = buf.byte_slice(2);
                    ch_state = "done";
                    progressed = true;
                } else {
                    var trl = buf.index_of("\r\n");
                    if (trl < 0) { return; }
                    buf = buf.byte_slice(trl + 2);
                    progressed = true;
                }
            } else if (ch_state == "done") {
                phase = "awaiting_respond";
                if (on_body_end != null) { on_body_end(); }
                return;
            }
        }
    }

    function _parse_hex(s) {
        if (s.byte_length == 0) { return null; }
        var n = 0;
        var i = 0;
        while (i < s.byte_length) {
            var b = s.byte_at(i);
            var d = -1;
            if (b >= 48 and b <= 57)        { d = b - 48; }
            else if (b >= 65 and b <= 70)   { d = b - 55; }
            else if (b >= 97 and b <= 102)  { d = b - 87; }
            else { return null; }
            n = n * 16 + d;
            i = i + 1;
        }
        return n;
    }

    conn.on_data(function (chunk) {
        if (conn_closed) { return; }
        if (max_body > 0 and buf.byte_length + chunk.byte_length > max_body) {
            if (phase == "awaiting_respond") { close_now(); }
            else                              { reject_too_large(); }
            return;
        }
        buf = buf + chunk;
        reset_idle();
        dispatch();
    });

    conn.on_end(function () { close_now(); });
    reset_idle();
}

function _split_path(p) {
    var raw = p.split("/");
    var out = [];
    var i = 0;
    while (i < raw.length) {
        if (raw[i].byte_length > 0) { out.push(raw[i]); }
        i = i + 1;
    }
    return out;
}

function _compile_pattern(pattern) {
    var segs = _split_path(pattern);
    var wild = false;
    if (segs.length > 0 and segs[segs.length - 1] == "*") {
        wild = true;
        segs.pop();
    }
    return { segs: segs, wild: wild };
}

function _match_pattern(pattern, req_segs) {
    var p = pattern.segs;
    var params = {};
    if (pattern.wild) {
        if (req_segs.length < p.length) { return null; }
        var i = 0;
        while (i < p.length) {
            if (p[i].starts_with(":")) {
                params[p[i].byte_slice(1)] = req_segs[i];
            } else if (p[i] != req_segs[i]) {
                return null;
            }
            i = i + 1;
        }
        var tail = "";
        while (i < req_segs.length) {
            if (tail.byte_length > 0) { tail = tail + "/"; }
            tail = tail + req_segs[i];
            i = i + 1;
        }
        params._wild = tail;
        return params;
    }
    if (req_segs.length != p.length) { return null; }
    var j = 0;
    while (j < p.length) {
        if (p[j].starts_with(":")) {
            params[p[j].byte_slice(1)] = req_segs[j];
        } else if (p[j] != req_segs[j]) {
            return null;
        }
        j = j + 1;
    }
    return params;
}

function app() {
    var routes        = [];
    var before_fns    = [];
    var after_fns     = [];
    var on_404_fns    = [];
    var on_error_fns  = [];

    var a = {};

    var add_route = function (method, path, fn) {
        routes.push({ method: method, pattern: _compile_pattern(path), fn: fn });
    };

    a.get    = function (p, fn) { add_route("GET",    p, fn); return a; };
    a.post   = function (p, fn) { add_route("POST",   p, fn); return a; };
    a.put    = function (p, fn) { add_route("PUT",    p, fn); return a; };
    a.patch  = function (p, fn) { add_route("PATCH",  p, fn); return a; };
    a.delete = function (p, fn) { add_route("DELETE", p, fn); return a; };
    a.head   = function (p, fn) { add_route("HEAD",   p, fn); return a; };
    a.any    = function (p, fn) { add_route(null,     p, fn); return a; };
    a.route  = function (m, p, fn) { add_route(m, p, fn); return a; };

    a.before   = function (fn) { before_fns.push(fn);   return a; };
    a.after    = function (fn) { after_fns.push(fn);    return a; };
    a.on_404   = function (fn) { on_404_fns.push(fn);   return a; };
    a.on_error = function (fn) { on_error_fns.push(fn); return a; };

    a.static = function (prefix, dir) {
        add_route("GET", prefix + "/*", function (req) {
            return _serve_static(req, dir);
        });
        return a;
    };

    a.listen = function (arg) {
        var opts = arg;
        if (type(arg) == "number") { opts = { port: arg }; }
        return serve(opts, function (req) {
            return _dispatch(req, routes, before_fns, after_fns, on_404_fns, on_error_fns);
        });
    };

    return a;
}

function _dispatch(req, routes, before_fns, after_fns, on_404_fns, on_error_fns) {
    var resp_value = null;
    var short_circuited = false;

    var i = 0;
    while (i < before_fns.length and not short_circuited) {
        var maybe = before_fns[i](req);
        if (maybe != null) {
            resp_value = maybe;
            short_circuited = true;
        }
        i = i + 1;
    }

    if (not short_circuited) {
        var req_segs = _split_path(req.path);
        var matched = false;
        var j = 0;
        while (j < routes.length and not matched) {
            var rt = routes[j];
            if (rt.method == null or rt.method == req.method) {
                var params = _match_pattern(rt.pattern, req_segs);
                if (params != null) {
                    _enrich_for_app(req, params);
                    matched = true;
                    try {
                        resp_value = rt.fn(req);
                    } catch (e) {
                        resp_value = _run_error(on_error_fns, req, e);
                    }
                }
            }
            j = j + 1;
        }
        if (not matched) {
            resp_value = _run_404(on_404_fns, req);
        }
    }

    if (req._upgraded) { return null; }

    var canonical = _coerce(resp_value);
    var k = 0;
    while (k < after_fns.length) {
        var maybe2 = after_fns[k](canonical, req);
        if (maybe2 != null) { canonical = _coerce(maybe2); }
        k = k + 1;
    }
    return canonical;
}

function _run_404(on_404_fns, req) {
    if (on_404_fns.length == 0) { return [404, "Not Found"]; }
    return on_404_fns[0](req);
}

function _run_error(on_error_fns, req, err) {
    if (on_error_fns.length == 0) { return [500, "Internal Server Error"]; }
    return on_error_fns[0](req, err);
}

function _serve_static(req, dir) {
    var rel = req.params._wild;
    if (rel == null) { rel = ""; }
    var segs = rel.split("/");
    var i = 0;
    while (i < segs.length) {
        if (segs[i] == ".." or segs[i] == ".") { return [403, "forbidden"]; }
        i = i + 1;
    }
    var full = dir + "/" + rel;
    if (not _io.exists(full)) { return [404, "not found"]; }
    var st = _io.stat(full);
    if (st.is_dir) { return [403, "is a directory"]; }
    return file(full);
}
