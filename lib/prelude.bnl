// Minimal embedded stdlib module to validate the loader pipeline.
// More substantial helpers will land here as Sprint 2+ progresses.

function greet(name) {
    return "Hello, " + name + "!";
}

function repeat(s, n) {
    var out = "";
    var i = 0;
    while (i < n) {
        out = out + s;
        i = i + 1;
    }
    return out;
}

// Bilingual alias — same value, two names.
var অভিবাদন = greet;
