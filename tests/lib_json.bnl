// json.bnl — parse and stringify written in pure bnl.
import "json" as json;

// Primitives.
print(json.parse("null"));
print(json.parse("true"));
print(json.parse("false"));
print(json.parse("42"));
print(json.parse("-3.14"));
print(json.parse("\"hello\""));

// String with escapes.
print(json.parse("\"a\\nb\\tc\""));

// Empty containers.
print(json.parse("[]"));
print(json.parse("{}"));

// Nested structure.
var got = json.parse("{\"name\":\"bnl\",\"version\":1,\"langs\":[\"bn\",\"en\"]}");
print(got.name);
print(got.version);
print(got.langs[0]);
print(got.langs[1]);

// Round-trip.
var data = {a: 1, b: [2, 3, true], c: null};
var s    = json.stringify(data);
var back = json.parse(s);
print(back.a);
print(back.b[2]);
print(back.c);

// String escape on stringify.
print(json.stringify("a\"b\\c\n"));

// Bilingual alias.
print(json.বিশ্লেষণ("[1,2,3]")[1]);
