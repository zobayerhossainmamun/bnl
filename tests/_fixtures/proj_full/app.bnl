// proj_full — comprehensive bnl resolution test.
//
// Exercises:
//   - All three built-in native modules         (sys, io, timers)
//   - Dep with bnl.json `main` field            (deps/mathlib/)
//   - Dep with index.bnl fallback               (deps/greeter/)
//   - Dep with <name>.bnl fallback              (deps/flat-utils/)
//   - Dep with bnl.json `native` field (plugin) (deps/mathx-plugin/)
//   - Walk-up resolution from a subdir          (./src/nested.bnl)
//
// The mathx-plugin dep is staged at build time: its bnl.json is generated
// with the per-OS filename, and the built plugin is copied alongside.

import "sys" as sys;
import "io"  as io;

import "mathlib"      as mathlib;
import "greeter"      as greeter;
import "flat-utils"   as flat;
import "mathx-plugin" as plugin;

import "./src/nested.bnl" as nested;

print("--- builtins ---");
print("sys.argc:",       sys.argc());
print("type(io):",       type(io));
print("type(io.read_file):", type(io.read_file));

print("--- pure-bnl deps ---");
print("mathlib.add(2,3):", mathlib.add(2, 3));
print("mathlib.PI:",       mathlib.PI);
print("greeter.hello:",    greeter.hello("alice"));
print("flat.tag:",         flat.tag());

print("--- plugin via deps ---");
print("plugin.cube(4):",   plugin.cube(4));
print("plugin.hypot(3,4):", plugin.hypot(3, 4));
print("plugin.greeting:",  plugin.greeting);

print("--- walk-up ---");
print("nested.compute:",   nested.compute());
