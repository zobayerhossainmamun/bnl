// Bare-name imports resolved via deps/ walk-up:
//   - my-lib       has bnl.json with `main` field
//   - no-manifest  no bnl.json, falls back to index.bnl
//   - flat-pkg     no bnl.json, no index.bnl — falls back to <name>.bnl
import "my-lib" as ml;
import "no-manifest" as nm;
import "flat-pkg" as flat;

// And a nested file that ALSO imports my-lib via walk-up from a subdir.
import "./src/nested.bnl" as nested;

print(ml.hello("alice"));
print(nm.ping());
print(flat.tag());
print(nested.greet());
