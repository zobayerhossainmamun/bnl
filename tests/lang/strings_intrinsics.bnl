// String intrinsics — codepoint-aware.
var s = "Hello, World";
print(s.slice(0, 5));
print(s.slice(7));
print(s.slice(-2, 100));     // clamps
print(s.char_at(7));
print(s.index_of("World"));
print(s.index_of("xyz"));
print(s.starts_with("Hello"));
print(s.ends_with("World"));
print("  trim me  ".trim());
print("MIxEd".to_lower());
print("MIxEd".to_upper());
print("a-b-c".split("-"));
print("abc".split(""));
print("foo bar foo".replace("foo", "baz"));

// Codepoint awareness on Bangla.
var bn = "হেলো, পৃথিবী";
print(bn.length);              // codepoints
print(bn.char_at(0));
print(bn.slice(0, 4));         // "হেলো"
print(bn.index_of("পৃথিবী"));

// to_number global.
print(to_number("3.14"));
print(to_number("  42  "));
print(to_number("nope"));
print(to_number("1.5x"));
print(to_number(7));           // already a number
