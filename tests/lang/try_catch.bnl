// try / catch / throw — both English and Bangla forms.

// 1. Throw a string, catch as a string.
try {
    throw "boom";
} catch (e) {
    print("caught:", e);
}

// 2. Throw a number — catch binds the value's actual type.
try {
    throw 42;
} catch (n) {
    print("caught number:", n, type(n));
}

// 3. Throw a map — structured payload.
try {
    throw {code: 500, msg: "server error"};
} catch (err) {
    print("caught map:", err.code, err.msg);
}

// 4. Throw from a deeper function call — propagates to nearest catch.
function inner() { throw "from inner"; }
function outer() { inner(); }
try {
    outer();
} catch (e) {
    print("propagated:", e);
}

// 5. Runtime-origin error (calling a non-callable) — `e` is the message string.
try {
    var x = 5;
    x();   // calling a number — runtime error
} catch (e) {
    print("runtime caught (type):", type(e));
}

// 6. Catch does NOT swallow `return`. Function returns from inside try.
function returns_via_try() {
    try {
        return "via-try";
    } catch (e) {
        return "via-catch";
    }
}
print("returns:", returns_via_try());

// 7. Code after a successful try block runs normally.
try {
    print("try ran");
} catch (e) {
    print("not reached");
}
print("after");

// 8. Bilingual form — চেষ্টা / ধরুন / নিক্ষেপ.
চেষ্টা {
    নিক্ষেপ "বাংলা ত্রুটি";
} ধরুন (ভুল) {
    print("বাংলা:", ভুল);
}

// 9. finally runs after try succeeds.
try {
    print("try-9");
} catch (e) {
    print("not reached");
} finally {
    print("finally-9");
}

// 10. finally runs after catch handles a throw.
try {
    throw "err-10";
} catch (e) {
    print("caught-10:", e);
} finally {
    print("finally-10");
}

// 11. try { ... } finally { ... }  (no catch). Throw propagates after finally.
function with_finally() {
    try {
        throw "err-11";
    } finally {
        print("finally-11-inner");
    }
}
try {
    with_finally();
} catch (e) {
    print("outer-caught-11:", e);
}

// 12. finally runs even when `return` is unwinding.
function returns_with_finally() {
    try {
        return "ret-value";
    } finally {
        print("finally-12-runs");
    }
}
print("returned:", returns_with_finally());

// 13. Bilingual finally — অবশেষে.
চেষ্টা {
    print("try-13");
} ধরুন (e) {
    print("not reached");
} অবশেষে {
    print("অবশেষে-13");
}
