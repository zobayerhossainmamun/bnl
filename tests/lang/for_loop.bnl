// for — both C-style and iterator (`for (var x of xs)`).

// 1. C-style: count 0..4
print("--- c-style ---");
for (var i = 0; i < 5; i = i + 1) {
    print(i);
}

// 2. C-style with all clauses optional → infinite (return breaks out via fn).
function find_first_even(xs) {
    var i = 0;
    for (; i < xs.length; i = i + 1) {
        if (xs[i] % 2 == 0) { return xs[i]; }
    }
    return null;
}
print("first even:", find_first_even([1, 3, 7, 8, 9]));

// 3. for-of over a list
print("--- for-of list ---");
var fruits = ["apple", "banana", "cherry"];
for (var f of fruits) {
    print(f);
}

// 4. for-of with computed list
print("--- for-of inline ---");
for (var n of [10, 20, 30]) {
    print(n * 2);
}

// 5. Loop variable scope: doesn't leak after the for.
for (var local = 100; local < 102; local = local + 1) {}
// `local` is gone here — accessing it would be a runtime error.
print("after loop scope ok");

// 6. Bilingual for-of using প্রতি / এর.
print("--- bilingual ---");
প্রতি (চলক x এর [1, 2, 3]) {
    লিখুন("ধাপ", x);
}
