// Same-program TCP server + client roundtrip via libuv.
import "net" as net;

var server = net.tcp_listen(0, function(conn) {
    conn.on_data(function(data) {
        print("server got:", data);
        conn.write("pong");
        conn.close();
    });
});

print("port_ok:", server.port > 0);

net.tcp_connect("127.0.0.1", server.port, function(err, conn) {
    if (err != null) { print("connect err:", err); return; }
    conn.on_data(function(data) {
        print("client got:", data);
        conn.close();
        server.close();
    });
    conn.write("ping");
});
