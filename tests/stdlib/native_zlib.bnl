// Round-trip compression/decompression.
import "zlib" as zlib;

var orig = "Hello, bnl! Hello, bnl! Hello, bnl! Hello, bnl!";
var compressed = zlib.compress(orig);
print(compressed.length > 0);
print(zlib.decompress(compressed) == orig);

// UTF-8 round-trip.
print(zlib.decompress(zlib.compress("হেলো, পৃথিবী!")));
