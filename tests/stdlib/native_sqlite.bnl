// Sqlite roundtrip — uses :memory: so no temp file management.
import "sqlite" as sqlite;

print("ver_ok:", sqlite.version().length > 0);

var db = sqlite.open(":memory:");

db.exec("CREATE TABLE users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, age INTEGER)");

db.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Alice", 30]);
print("id1:",      db.last_insert_id());
print("changes1:", db.changes());

db.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Bob",   25]);
db.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Carol", 40]);

// Parameterized query.
var rows = db.query("SELECT id, name, age FROM users WHERE age >= ? ORDER BY id", [28]);
print("count:", rows.length);
print("r0:",    rows[0].name, rows[0].age);
print("r1:",    rows[1].name, rows[1].age);

// query_one — first row or null.
var alice = db.query_one("SELECT name, age FROM users WHERE id = ?", [1]);
print("alice:", alice.name, alice.age);

var none = db.query_one("SELECT * FROM users WHERE id = ?", [999]);
print("none:", none);

// NULL handling.
db.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["NoAge", null]);
var na = db.query_one("SELECT name, age FROM users WHERE name = ?", ["NoAge"]);
print("na_age:", na.age);

// Update reports changes.
db.exec("UPDATE users SET age = age + 1 WHERE age >= ?", [25]);
print("changes_upd:", db.changes());

db.close();
