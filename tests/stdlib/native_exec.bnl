// Native exec primitive — child process spawn with stdin/stdout/stderr
// pipes. Imports "_exec" because the public "exec" name belongs to
// lib/exec.bnl (which builds run / run_with_input on top of this).
import "_exec" as exec;
import "sys"   as sys;

print("--- spawn echo ---");
var out      = "";
var ec       = null;
var stdout_d = false;
var done     = false;

function check() {
    if (done) { return; }
    if (stdout_d and ec != null) {
        done = true;
        print("stdout:", out.trim());
        print("code:", ec);
    }
}

// `echo` is a shell built-in on Windows (so we go through cmd.exe), but a
// real executable on Unix where libuv's PATH lookup finds it directly.
var cmd;
var argv;
if (sys.platform == "windows") {
    cmd  = "cmd.exe";
    argv = ["/c", "echo", "spawn-hello"];
} else {
    cmd  = "echo";
    argv = ["spawn-hello"];
}

var p = exec.spawn(cmd, argv, null,
    function (code, sig) { ec = code; check(); });

print("pid > 0:", p.pid > 0);
p.stdout.on_data(function (d) { out = out + d; });
p.stdout.on_end (function ()  { stdout_d = true; check(); });
