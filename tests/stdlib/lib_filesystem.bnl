// fileSystem.bnl — composed helpers over the native io module.
import "fileSystem" as fs;

var root = "_bnl_fs_test";
if (fs.exists(root)) { fs.remove(root); }

// mkdir is recursive; one call creates root + intermediate dirs.
fs.mkdir(root + "/a/sub");
fs.write_text(root + "/a/hello.txt", "hi\nworld\n");
fs.write_json(root + "/a/sub/data.json", {n: 42, name: "x"});

print("dir_a:",  fs.is_dir(root + "/a"));
print("file_t:", fs.is_file(root + "/a/hello.txt"));

// read_lines strips trailing newlines/CR.
var lines = fs.read_lines(root + "/a/hello.txt");
print("lines:", lines.length);
print("l0:",    lines[0]);
print("l1:",    lines[1]);

// read_json roundtrip.
var data = fs.read_json(root + "/a/sub/data.json");
print("n:", data.n);
print("name:", data.name);

// stat exposes byte count + flags.
var st = fs.stat(root + "/a/hello.txt");
print("bytes:", st.bytes);   // "hi\nworld\n" -> 9 bytes
print("isf:",   st.is_file);
print("isd:",   st.is_dir);

// walk visits every entry depth-first; just count rather than test order.
var seen = [];
fs.walk(root, function(p, info) { seen.push(p); });
print("walked:", seen.length);

// append + copy_tree.
fs.append_file(root + "/a/hello.txt", "more\n");
fs.copy_tree(root + "/a", root + "/b");
print("copy_txt:", fs.read_text(root + "/b/hello.txt"));

// rename moves a file.
fs.rename(root + "/a/hello.txt", root + "/a/renamed.txt");
print("renamed:", fs.is_file(root + "/a/renamed.txt"));

fs.remove(root);
print("gone:", not fs.exists(root));
