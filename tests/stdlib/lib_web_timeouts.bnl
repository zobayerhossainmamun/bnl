// Server max_body_size + client request timeout.
import "web"     as web;
import "request" as r;

print("--- 1. client timeout fires on a never-responding server ---");

// Handler returns null (async) and never calls req.respond — the conn just
// hangs until the client gives up.
var hang_server = web.serve({port: 0}, function (req) {
    return null;
});

r.request({
    url:     "http://127.0.0.1:" + str(hang_server.port) + "/",
    method:  "GET",
    timeout: 200
}, function (err, resp) {
    print("err is not null:",        err != null);
    print("err mentions timeout:",   err.index_of("timeout") >= 0);
    print("resp is null:",           resp == null);
    hang_server.close();

    print("--- 2. server returns 413 when body exceeds max_body_size ---");

    var small_server = web.serve({port: 0, max_body_size: 100},
        function (req) { return "should not arrive"; });

    var big = "";
    var i = 0;
    while (i < 500) { big = big + "x"; i = i + 1; }

    r.post("http://127.0.0.1:" + str(small_server.port) + "/", big,
        function (e2, r2) {
            print("413 status:", r2.status);
            print("413 conn:",   r2.headers["connection"]);
            print("413 body:",   r2.body);
            small_server.close();
        });
});
