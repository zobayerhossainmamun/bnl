// Embedded bnl stdlib — web module (HTTP server). End-to-end roundtrip
// against a raw TCP client built from net + http.
import "web"  as web;
import "net"  as net;
import "http" as http;

var server = web.serve({port: 0}, function (req) {
    if (req.path == "/hello") {
        var name = req.query.name;
        if (name == null) { name = "world"; }
        return { status: 200, body: "hello, " + name };
    }
    if (req.path == "/text") {
        return web.text("plain");
    }
    if (req.path == "/json") {
        return web.json({ok: true, n: 7});
    }
    if (req.path == "/echo-json" and req.method == "POST") {
        var body = web.parse_json(req);
        return web.json({echo: body.value});
    }
    return { status: 404, body: "nope" };
});

print("port valid:", server.port > 0);

// Helper: open a raw TCP client, send one request, deliver parsed response.
function send(method, path, body, cb) {
    net.tcp_connect("127.0.0.1", server.port, function (err, client) {
        if (err != null) { cb(err, null); return; }
        var buf = "";
        client.on_data(function (d) { buf = buf + d; });
        client.on_end(function () {
            cb(null, http.parse_response(buf, true));
        });
        var req = method + " " + path + " HTTP/1.1\r\nHost: x\r\n";
        if (body != null and body.byte_length > 0) {
            req = req + "Content-Type: application/json\r\n";
            req = req + "Content-Length: " + str(body.byte_length) + "\r\n";
        }
        req = req + "\r\n";
        if (body != null) { req = req + body; }
        client.write(req);
    });
}

function get(path, cb) { send("GET", path, null, cb); }

// Sequential roundtrips, then close the listener.
get("/hello?name=alice", function (e1, r1) {
    print("hello:", r1.status, r1.body);
    get("/text", function (e2, r2) {
        print("text:", r2.status, r2.body);
        print("text ct:", r2.headers["content-type"]);
        get("/json", function (e3, r3) {
            print("json:", r3.status, r3.body);
            print("json ct:", r3.headers["content-type"]);
            send("POST", "/echo-json", "{\"value\":42}", function (e4, r4) {
                print("echo:", r4.status, r4.body);
                get("/missing", function (e5, r5) {
                    print("404:", r5.status, r5.body);
                    server.close();
                });
            });
        });
    });
});
