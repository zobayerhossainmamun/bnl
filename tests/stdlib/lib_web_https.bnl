// In-process HTTPS roundtrip: web.serve with TLS + request.get with verify off
// (the cert is self-signed for localhost).
import "web"     as web;
import "request" as request;

var server = web.serve({
    port: 0,
    tls:  {
        cert: "../_fixtures/tls/cert.pem",
        key:  "../_fixtures/tls/key.pem"
    }
}, function(req) {
    return {
        status:  200,
        headers: {"Content-Type": "text/plain"},
        body:    "tls hi " + req.url
    };
});

print("port_ok:", server.port > 0);

var target = "https://localhost:" + str(server.port) + "/world";

request.send({url: target, tls: {verify: false}}, function(err, resp) {
    if (err != null) { print("err:", err); server.close(); return null; }
    print("status:",      resp.status);
    print("status_text:", resp.status_text);
    print("ctype:",       resp.header("content-type"));
    print("body:",        resp.body);
    server.close();
});
