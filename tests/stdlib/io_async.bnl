// Async file I/O via libuv's worker thread pool. Targets the native module
// directly (callback-style `read_file_async(path, cb)`). User-facing async
// code goes through lib/io.bnl which futurifies these.
import "_io" as io;

var path = "_bnl_async_io_test.tmp";

// Schedule write -> read -> verify -> cleanup, fully async.
io.write_file_async(path, "Hello async, বন্ধু!", function(err) {
    if (err != null) { print("write err:", err); return; }
    io.read_file_async(path, function(rerr, data) {
        if (rerr != null) { print("read err:", rerr); return; }
        print(data);
        io.remove(path);
        print("done");
    });
});

print("scheduled");
