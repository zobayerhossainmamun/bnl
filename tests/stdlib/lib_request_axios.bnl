// Axios-style features of lib/request: verb methods with optional config,
// json/form auto-encode, params query serialization, resp.data + resp.ok,
// r.create() instances with before/after interceptors, r.download to disk.
// Uses the wait-based API throughout.
import "web"     as web;
import "request" as r;
import "json"    as json;
import "io"      as io;

var server = web.serve({port: 0}, function (req) {
    if (req.path == "/method") {
        return { status: 200, body: req.method };
    }
    if (req.path == "/echo-body") {
        return { status: 200,
                 headers: { "Content-Type": req.headers["content-type"] },
                 body: req.body };
    }
    if (req.path == "/echo-headers") {
        return { status: 200,
                 headers: { "Content-Type": "application/json; charset=utf-8" },
                 body: json.stringify(req.headers) };
    }
    if (req.path == "/query") {
        return { status: 200,
                 headers: { "Content-Type": "application/json; charset=utf-8" },
                 body: json.stringify(req.query) };
    }
    if (req.path == "/blob") {
        return { status: 200, body: "blob content for download test" };
    }
    return { status: 404, body: "not found" };
});

var base = "http://127.0.0.1:" + str(server.port);
print("port valid:", server.port > 0);

function run() {
    // ---- Verb methods round-trip method name --------------------------------
    var r1 = wait r.put(base + "/method", "x", null);
    print("PUT:",   r1.body);
    var r2 = wait r.patch(base + "/method", "x", null);
    print("PATCH:", r2.body);
    var r3 = wait r.delete(base + "/method", null);
    print("DELETE:", r3.body);
    var r4 = wait r.head(base + "/method", null);
    print("HEAD status:", r4.status);

    // ---- JSON body auto-encoded when data is a map --------------------------
    var rj = wait r.post(base + "/echo-body", { name: "alice" }, null);
    print("json ct:", rj.headers["content-type"]);
    print("json body:", rj.body);
    print("json data.name:", rj.data.name);

    // ---- Form-encoded body via post_form ------------------------------------
    var rf = wait r.post_form(base + "/echo-body", { user: "alice", n: 7 }, null);
    print("form ct:", rf.headers["content-type"]);
    print("form has user:", rf.body.index_of("user=alice") >= 0);
    print("form has n:",    rf.body.index_of("n=7")        >= 0);

    // ---- Params auto-appended as query string (via config arg!) -------------
    var rq = wait r.get(base + "/query", { params: { a: "1", b: "two" } });
    print("params a:", rq.data.a);
    print("params b:", rq.data.b);

    // ---- resp.ok flag for 4xx -----------------------------------------------
    var r404 = wait r.get(base + "/missing", null);
    print("404 ok:", r404.ok);
    print("404 status:", r404.status);

    // ---- Download to disk, verify bytes_written + file contents -------------
    var dest = "_request_axios_dl.bin";
    var rd = wait r.download(base + "/blob", dest, null);
    print("download status:", rd.status);
    print("download ok:", rd.ok);
    print("download bytes:", rd.bytes_written);
    print("file contents:", io.read_file(dest));
    io.remove(dest);

    // ---- Instance with base_url + before/after interceptors -----------------
    var api = r.create({ base_url: base, headers: { "X-Custom": "yes" } });
    var hits = 0;
    api.before(function (cfg) {
        hits = hits + 1;
        cfg.headers["X-Trace"] = "abc";
        return cfg;
    });
    api.after(function (resp) {
        resp.from_after = true;
        return resp;
    });
    var ri = wait api.get("/echo-headers", null);
    print("hits:", hits);
    print("from_after:", ri.from_after);
    print("x-custom:", ri.data["x-custom"]);
    print("x-trace:",  ri.data["x-trace"]);

    server.close();
}
run().fail(function (e) { print("err:", e); server.close(); });
