// End-to-end exercise of the async composer library. We chain each step
// through async.series itself so the test runner sees deterministic output,
// even though the inner composers (parallel/each/map) launch their work
// concurrently. timers.set(0, ...) is the source of "real" deferral.
import "async"  as async;
import "timers" as timers;

// task_of(v) → a one-shot task that defers via timers and calls back with v.
function task_of(val) {
    return function (cb) {
        timers.set(0, function () { cb(null, val); });
    };
}

// task_err(msg) → defers and reports an error.
function task_err(msg) {
    return function (cb) {
        timers.set(0, function () { cb(msg, null); });
    };
}

// Iter that doubles its item (for map / map_series).
function double_iter(item, cb) {
    timers.set(0, function () { cb(null, item * 2); });
}


// ---- 1. series, happy path ----
function step_series(next) {
    print("--- series ---");
    async.series([task_of("a"), task_of("b"), task_of("c")],
        function (err, r) {
            print("err is null:", err == null);
            print("len:", r.length);
            print(r[0], r[1], r[2]);
            next(null, null);
        });
}

// ---- 2. series, error stops it ----
function step_series_err(next) {
    print("--- series error ---");
    async.series([task_of("a"), task_err("boom"), task_of("c")],
        function (err, r) {
            print("err:", err);
            print("len:", r.length);
            print(r[0]);
            next(null, null);
        });
}

// ---- 3. parallel, results in input order ----
function step_parallel(next) {
    print("--- parallel ---");
    async.parallel([task_of(1), task_of(2), task_of(3)],
        function (err, r) {
            print("err is null:", err == null);
            print(r[0], r[1], r[2]);
            next(null, null);
        });
}

// ---- 4. parallel, one task fails ----
function step_parallel_err(next) {
    print("--- parallel error ---");
    async.parallel([task_of("a"), task_err("nope"), task_of("c")],
        function (err, r) {
            print("err:", err);
            next(null, null);
        });
}

// ---- 5. waterfall threads prev through ----
function step_waterfall(next) {
    print("--- waterfall ---");
    async.waterfall([
        function (prev, cb) { timers.set(0, function () { cb(null, 1);       }); },
        function (prev, cb) { timers.set(0, function () { cb(null, prev + 10); }); },
        function (prev, cb) { timers.set(0, function () { cb(null, prev * 2);  }); }
    ], function (err, final) {
        print("err is null:", err == null);
        print("final:", final);
        next(null, null);
    });
}

// ---- 6. each (parallel, no results) ----
function step_each(next) {
    print("--- each ---");
    var count = 0;
    async.each([10, 20, 30], function (item, cb) {
        timers.set(0, function () { count = count + 1; cb(null); });
    }, function (err) {
        print("err is null:", err == null);
        print("count:", count);
        next(null, null);
    });
}

// ---- 7. each_series — sequential ordering preserved ----
function step_each_series(next) {
    print("--- each_series ---");
    var order = [];
    async.each_series([10, 20, 30], function (item, cb) {
        timers.set(0, function () { order.push(item); cb(null); });
    }, function (err) {
        print("err is null:", err == null);
        print(order[0], order[1], order[2]);
        next(null, null);
    });
}

// ---- 8. map (parallel, results in input order) ----
function step_map(next) {
    print("--- map ---");
    async.map([1, 2, 3], double_iter, function (err, r) {
        print("err is null:", err == null);
        print(r[0], r[1], r[2]);
        next(null, null);
    });
}

// ---- 9. map_series ----
function step_map_series(next) {
    print("--- map_series ---");
    async.map_series([1, 2, 3], double_iter, function (err, r) {
        print("err is null:", err == null);
        print(r[0], r[1], r[2]);
        next(null, null);
    });
}

// ---- 10. apply_map — sync fn, collect results ----
function step_apply_map(next) {
    print("--- apply_map ---");
    async.apply_map([1, 2, 3, 4], function (n) { return n * 10; },
        function (err, r) {
            print("err is null:", err == null);
            print(r[0], r[1], r[2], r[3]);
            next(null, null);
        });
}

// ---- 11. apply_each_series — sync fn, sequential side effects ----
function step_apply_each_series(next) {
    print("--- apply_each_series ---");
    var seen = [];
    async.apply_each_series(["a", "b", "c"], function (item) {
        seen.push(item);
    }, function (err) {
        print("err is null:", err == null);
        print(seen[0], seen[1], seen[2]);
        next(null, null);
    });
}

// ---- 12. apply_map error — throw inside fn becomes done(err) ----
function step_apply_map_throw(next) {
    print("--- apply_map throw ---");
    async.apply_map([1, 2, 3], function (n) {
        if (n == 2) { throw "rejected: " + str(n); }
        return n;
    }, function (err, _r) {
        print("err:", err);
        next(null, null);
    });
}


async.series([
    step_series,
    step_series_err,
    step_parallel,
    step_parallel_err,
    step_waterfall,
    step_each,
    step_each_series,
    step_map,
    step_map_series,
    step_apply_map,
    step_apply_each_series,
    step_apply_map_throw
], function (err, _) {
    print("--- done ---");
});
