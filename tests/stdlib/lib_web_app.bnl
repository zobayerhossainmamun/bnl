// High-level web.app() — routing with :params, return-value coercion,
// before/after/on_404/on_error hooks, multipart upload via req.file()/
// req.fields(), and static file serving (web.file streaming).
import "web"     as web;
import "request" as r;
import "io"      as io;
import "json"    as json;

// ---- Build the app ----------------------------------------------------------

var app = web.app();

app.get("/", function (req) {
    return "hello";                                  // → 200 text/plain "hello"
});

app.get("/users", function (req) {
    return [{ id: 1, name: "alice" }, { id: 2, name: "bob" }];  // → JSON
});

app.get("/users/:id", function (req) {
    return { id: req.params.id, name: "x" };
});

app.post("/users", function (req) {
    var u = req.json();
    return [201, { id: 42, echo: u.name }];          // status + auto JSON
});

app.put("/echo-method", function (req) { return req.method; });
app.delete("/del", function (req) { return null; }); // → 204

app.post("/upload", function (req) {
    var file = req.file("photo");
    if (file == null) { return [400, "no file"]; }
    var fields = req.fields();
    return {
        filename:    file.filename,
        bytes:       file.body.byte_length,
        body_text:   file.body,
        field_name:  fields.user
    };
});

app.get("/boom", function (req) { throw "kaboom"; });

app.before(function (req) {
    if (req.path.starts_with("/locked")) {
        return [401, "auth required"];               // short-circuit
    }
    return null;
});

app.after(function (resp, req) {
    if (type(resp) == "map") { resp.headers["X-Trace"] = "ok"; }
    return resp;
});

app.on_404(function (req) {
    return [404, "custom 404 for " + req.path];
});

app.on_error(function (req, err) {
    return [500, "caught: " + str(err)];
});

// Static fixture — write a tmp file then serve it.
io.mkdir("_web_app_pub");
io.write_file("_web_app_pub/hello.txt", "static file body");
app.static("/assets", "_web_app_pub");

var server = app.listen({ port: 0 });
var base   = "http://127.0.0.1:" + str(server.port);
print("port valid:", server.port > 0);

function cleanup() {
    server.close();
    io.remove("_web_app_pub/hello.txt");
    io.remove("_web_app_pub");
}

function run() {
    // ---- Step 1: simple string + list responses ---------------------------
    var resp = wait r.get(base + "/");
    print("root:", resp.body);
    print("root ct:", resp.headers["content-type"]);
    print("after-hook:", resp.headers["x-trace"]);

    var r2 = wait r.get(base + "/users");
    print("users ct:", r2.headers["content-type"]);
    print("users[0].name:", r2.data[0].name);
    print("users[1].id:",   r2.data[1].id);

    // ---- Step 2: path params + verb dispatch ------------------------------
    var ru = wait r.get(base + "/users/42");
    print("user id:", ru.data.id);
    var rp = wait r.put(base + "/echo-method", "x");
    print("verb dispatch:", rp.body);

    // ---- Step 3: status + body shorthand ----------------------------------
    var rc = wait r.post(base + "/users", { name: "alice" });
    print("created status:", rc.status);
    print("created id:",     rc.data.id);
    print("created echo:",   rc.data.echo);

    // ---- Step 4: null returns 204 -----------------------------------------
    var rd = wait r.delete(base + "/del");
    print("204 status:", rd.status);
    print("204 body len:", rd.body.byte_length);

    // ---- Step 5: before hook short-circuit --------------------------------
    var rl = wait r.get(base + "/locked/anything");
    print("locked status:", rl.status);
    print("locked body:",   rl.body);

    // ---- Step 6: on_404 custom handler ------------------------------------
    var r404 = wait r.get(base + "/no-such-thing");
    print("404 status:", r404.status);
    print("404 body:",   r404.body);

    // ---- Step 7: on_error catches thrown handler exceptions ---------------
    var rb = wait r.get(base + "/boom");
    print("error status:", rb.status);
    print("error body:",   rb.body);

    // ---- Step 8: file upload round-trip via request.upload ----------------
    io.write_file("_web_app_upload.txt", "uploaded payload");
    var rup = wait r.upload(base + "/upload",
        { path: "_web_app_upload.txt", name: "photo",
          filename: "report.txt", content_type: "text/plain" },
        { fields: { user: "alice" } });
    print("upload status:", rup.status);
    var got = rup.data;
    print("upload filename:",   got.filename);
    print("upload bytes:",      got.bytes);
    print("upload body_text:",  got.body_text);
    print("upload field_name:", got.field_name);
    io.remove("_web_app_upload.txt");

    // ---- Step 9: static file ----------------------------------------------
    var rs = wait r.get(base + "/assets/hello.txt");
    print("static status:",  rs.status);
    print("static ct:",      rs.headers["content-type"]);
    print("static body:",    rs.body);

    var rm = wait r.get(base + "/assets/nope.txt");
    print("static missing:", rm.status);

    cleanup();
}
run().fail(function (e) { print("err:", e); cleanup(); });
