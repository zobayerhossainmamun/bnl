// Embedded bnl stdlib — request module (HTTP client). End-to-end against an
// in-process web.serve instance, using the wait-based API.
import "web"     as web;
import "request" as req;

var server = web.serve({port: 0}, function (r) {
    if (r.path == "/hello") {
        var name = r.query.name;
        if (name == null) { name = "world"; }
        return { status: 200, body: "hello, " + name };
    }
    if (r.path == "/echo" and r.method == "POST") {
        return { status: 200, body: "echo: " + r.body };
    }
    return { status: 404, body: "nope" };
});

var base = "http://127.0.0.1:" + str(server.port);
print("port valid:", server.port > 0);

function run() {
    var r1 = wait req.get(base + "/hello?name=alice");
    print("hello:", r1.status, r1.body);
    print("ct:",    r1.headers["content-type"]);

    var r2 = wait req.post(base + "/echo", "ping payload");
    print("echo:", r2.status, r2.body);

    var r3 = wait req.get(base + "/missing");
    print("404:", r3.status, r3.body);

    server.close();
}
run().fail(function (e) { print("err:", e); server.close(); });
