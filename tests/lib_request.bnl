// In-process roundtrip: lib/http server + lib/request client.
import "http"    as http;
import "request" as request;

var server = http.serve(0, function(req) {
    return {
        status:  200,
        headers: {"Content-Type": "text/plain"},
        body:    "hi " + req.url
    };
});

print("port_ok:", server.port > 0);

// Build the URL from the bound port. Loopback so DNS resolve trivially returns
// 127.0.0.1.
var target = "http://127.0.0.1:" + str(server.port) + "/world";

request.get(target, function(err, resp) {
    if (err != null) { print("err:", err); server.close(); return null; }
    print("status:",      resp.status);
    print("status_text:", resp.status_text);
    print("ctype:",       resp.header("content-type"));
    print("body:",        resp.body);
    server.close();
});
