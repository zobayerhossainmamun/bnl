// List literals, indexing, intrinsic methods.
var xs = [1, 2, 3];
print(xs.length);
print(xs[0], xs[1], xs[2]);

xs.push(4);
print(xs.length, xs[3]);

var last = xs.pop();
print(last, xs.length);

// Nested lists.
var nested = [[1, 2], [3, 4]];
print(nested[0][1], nested[1][0]);

// Index assignment.
xs[0] = 99;
print(xs[0]);

// Empty list.
var empty = [];
print(empty.length, empty.pop());

// Heterogeneous (and Bangla strings).
var mix = [1, "দুই", true, null];
print(mix[0], mix[1], mix[2], mix[3]);

// Display form.
print([10, 20, "hi"]);
