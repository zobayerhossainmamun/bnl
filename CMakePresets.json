{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "_dev",
            "hidden": true,
            "inherits": "_base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "_release",
            "hidden": true,
            "inherits": "_base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },

        {
            "name": "windows",
            "displayName": "Windows dev  (x64, Debug, dynamic CRT)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "windows-x86",
            "displayName": "Windows dev  (x86, Debug, dynamic CRT)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "architecture": { "value": "x86", "strategy": "external" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows"
            }
        },
        {
            "name": "linux",
            "displayName": "Linux dev    (x64, Debug)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux"
            }
        },
        {
            "name": "linux-x86",
            "displayName": "Linux dev    (x86, Debug)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-linux",
                "CMAKE_C_FLAGS": "-m32",
                "CMAKE_CXX_FLAGS": "-m32"
            }
        },
        {
            "name": "macos",
            "displayName": "macOS dev    (arm64, Debug)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm64-osx",
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            }
        },
        {
            "name": "macos-x64",
            "displayName": "macOS dev    (x64 Intel, Debug)",
            "inherits": "_dev",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-osx",
                "CMAKE_OSX_ARCHITECTURES": "x86_64"
            }
        },

        {
            "name": "windows-release",
            "displayName": "Windows ship (x64, Release, deps static, single bnl.exe)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
            }
        },
        {
            "name": "windows-x86-release",
            "displayName": "Windows ship (x86, Release, deps static, single bnl.exe)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
            "architecture": { "value": "x86", "strategy": "external" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux ship   (x64, Release, deps static + libstdc++/libgcc static, single bnl binary)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux",
                "CMAKE_EXE_LINKER_FLAGS": "-static-libstdc++ -static-libgcc",
                "CMAKE_SHARED_LINKER_FLAGS": "-static-libstdc++ -static-libgcc"
            }
        },
        {
            "name": "linux-x86-release",
            "displayName": "Linux ship   (x86, Release, deps static + libstdc++/libgcc static, single bnl binary)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-linux",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
                "CMAKE_C_FLAGS": "-m32",
                "CMAKE_CXX_FLAGS": "-m32",
                "CMAKE_EXE_LINKER_FLAGS": "-m32 -static-libstdc++ -static-libgcc",
                "CMAKE_SHARED_LINKER_FLAGS": "-m32 -static-libstdc++ -static-libgcc"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS ship   (arm64, Release, deps static, single bnl binary)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm64-osx",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_EXE_LINKER_FLAGS": "-Wl,-dead_strip"
            }
        },
        {
            "name": "macos-x64-release",
            "displayName": "macOS ship   (x64 Intel, Release, deps static, single bnl binary)",
            "inherits": "_release",
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-osx",
                "CMAKE_OSX_ARCHITECTURES": "x86_64",
                "CMAKE_EXE_LINKER_FLAGS": "-Wl,-dead_strip"
            }
        }
    ],
    "buildPresets": [
        { "name": "windows",             "configurePreset": "windows"             },
        { "name": "windows-x86",         "configurePreset": "windows-x86"         },
        { "name": "linux",               "configurePreset": "linux"               },
        { "name": "linux-x86",           "configurePreset": "linux-x86"           },
        { "name": "macos",               "configurePreset": "macos"               },
        { "name": "macos-x64",           "configurePreset": "macos-x64"           },
        { "name": "windows-release",     "configurePreset": "windows-release",     "configuration": "Release" },
        { "name": "windows-x86-release", "configurePreset": "windows-x86-release", "configuration": "Release" },
        { "name": "linux-release",       "configurePreset": "linux-release",       "configuration": "Release" },
        { "name": "linux-x86-release",   "configurePreset": "linux-x86-release",   "configuration": "Release" },
        { "name": "macos-release",       "configurePreset": "macos-release",       "configuration": "Release" },
        { "name": "macos-x64-release",   "configurePreset": "macos-x64-release",   "configuration": "Release" }
    ]
}
